<%- include('../partials/head') %>
<%- include('../partials/flash') %>

<section class="page-hero card executive-hero">
  <div class="page-hero-copy">
    <span class="page-kicker"><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Panel administrativo</span>
    <h2>Control ejecutivo de la operación clínica</h2>
    <p>Visualice el comportamiento de la demanda y administre la agenda con rapidez.</p>
    <p class="executive-subtitle">Indicadores clave y próximas atenciones en una vista compacta y accionable.</p>
  </div>
  <div class="executive-hero-media">
    <img src="/img/hero-dashboard.svg" alt="Resumen visual del panel administrativo" />
  </div>
</section>

<section class="metrics-grid dashboard-section-gap">
  <article class="metric card">
    <h3><img src="/img/icon-calendar.svg" alt="" class="metric-icon" />Total de citas</h3>
    <p><%= summary.total %></p>
  </article>
  <article class="metric card">
    <h3><img src="/img/icon-calendar.svg" alt="" class="metric-icon" />Pendientes</h3>
    <p><%= summary.pending %></p>
  </article>
  <article class="metric card">
    <h3><img src="/img/icon-user.svg" alt="" class="metric-icon" />Completadas</h3>
    <p><%= summary.completed %></p>
  </article>
  <article class="metric card">
    <h3><img src="/img/icon-doctor.svg" alt="" class="metric-icon" />Canceladas</h3>
    <p><%= summary.cancelled %></p>
  </article>
</section>

<section class="card dashboard-section-gap dashboard-table-card">
  <h2>Próximas citas</h2>
  <table>
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Hora</th>
        <th>Paciente</th>
        <th>Médico</th>
        <th>Especialidad</th>
        <th>Estado</th>
      </tr>
    </thead>
    <tbody>
      <% summary.upcoming.forEach((a) => { %>
        <tr>
          <td><%= a.appointment_date %></td>
          <td><%= a.start_time %></td>
          <td><%= a.patient_name %></td>
          <td><%= a.doctor_name %></td>
          <td><%= a.specialty %></td>
          <td><span class="status status-<%= a.status %>"><%= a.status %></span></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../partials/foot') %>