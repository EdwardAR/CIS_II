<%- include('../partials/head') %>
<%- include('../partials/flash') %>

<%
  function fieldError(field) {
    if (!formErrors || !formErrors.length) return '';
    const e = formErrors.find(function(err) { return err.path === field; });
    return e ? e.msg : '';
  }
  function hasError(field) { return fieldError(field) ? 'auth-input-error' : ''; }
%>

<section class="auth-shell auth-shell-wide">

  <!-- SIDEBAR IZQUIERDO -->
  <aside class="auth-sidebar">
    <div class="auth-sidebar-top">
      <a href="/" class="auth-back-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Volver al inicio
      </a>
    </div>

    <div class="auth-sidebar-photo">
      <img src="/img/clinic-hero-1.jpg" alt="Equipo clínico en consulta" />
      <div class="auth-sidebar-photo-overlay">
        <div class="auth-sidebar-brand">
          <img src="/img/logo-mark.svg" alt="" class="auth-sidebar-logo" />
          <div>
            <strong>Policlínico San Juan Bautista</strong>
            <span>Sistema de Gestión Clínica</span>
          </div>
        </div>
        <blockquote class="auth-sidebar-quote">
          "Tu salud, bien gestionada desde el primer día."
        </blockquote>
      </div>
    </div>

    <div class="auth-sidebar-features">
      <div class="auth-feature">
        <span class="auth-feature-icon auth-feature-green">
          <img src="/img/icon-calendar.svg" alt="" />
        </span>
        <div>
          <strong>Reserva citas en segundos</strong>
          <span>Elige especialidad, médico y fecha sin llamadas</span>
        </div>
      </div>
      <div class="auth-feature">
        <span class="auth-feature-icon auth-feature-blue">
          <img src="/img/icon-clock.svg" alt="" />
        </span>
        <div>
          <strong>Recordatorios automáticos</strong>
          <span>Te avisamos antes de cada cita programada</span>
        </div>
      </div>
      <div class="auth-feature">
        <span class="auth-feature-icon auth-feature-purple">
          <img src="/img/icon-shield.svg" alt="" />
        </span>
        <div>
          <strong>Historial siempre disponible</strong>
          <span>Consulta tus atenciones pasadas cuando quieras</span>
        </div>
      </div>
      <div class="auth-feature">
        <span class="auth-feature-icon auth-feature-orange">
          <img src="/img/icon-doctor.svg" alt="" />
        </span>
        <div>
          <strong>+11 especialidades médicas</strong>
          <span>Cardiología, pediatría, dermatología y más</span>
        </div>
      </div>
    </div>

    <div class="auth-sidebar-stats">
      <div class="auth-sidebar-stat">
        <strong>Gratis</strong>
        <span>Sin costo</span>
      </div>
      <div class="auth-sidebar-stat-sep"></div>
      <div class="auth-sidebar-stat">
        <strong>2 min</strong>
        <span>Tiempo de alta</span>
      </div>
      <div class="auth-sidebar-stat-sep"></div>
      <div class="auth-sidebar-stat">
        <strong>100%</strong>
        <span>En línea</span>
      </div>
    </div>
  </aside>

  <!-- PANEL FORMULARIO -->
  <main class="auth-panel">

    <div class="auth-panel-header">
      <div class="auth-panel-logo-mobile">
        <img src="/img/logo-mark.svg" alt="Logo" />
        <span>Policlínico San Juan Bautista</span>
      </div>
      <span class="auth-panel-kicker">
        <img src="/img/icon-user.svg" alt="" />
        Alta de paciente
      </span>
      <h1 class="auth-panel-title">Crear cuenta</h1>
      <p class="auth-panel-sub">Completa tus datos en menos de 2 minutos y reserva tu primera cita hoy.</p>
    </div>

    <form method="post" action="/auth/register" class="auth-form" id="registerForm" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

      <!-- GRUPO 1: Información personal -->
      <div class="auth-group">
        <div class="auth-group-label">
          <span class="auth-group-num">1</span>
          Información personal
        </div>

        <div class="auth-field-row">
          <div class="auth-field" data-field="full_name">
            <label for="reg-full_name">Nombre completo <span class="auth-required">*</span></label>
            <div class="auth-input-wrap">
              <img src="/img/icon-user.svg" alt="" class="auth-input-icon" />
              <input type="text" id="reg-full_name" name="full_name"
                placeholder="Ej. María García López"
                class="auth-input <%= hasError('full_name') %>"
                autocomplete="name" required minlength="5" />
            </div>
            <span class="auth-field-error" data-error="full_name" style="display:<%= fieldError('full_name') ? '' : 'none' %>"><%= fieldError('full_name') || '' %></span>
          </div>

          <div class="auth-field" data-field="dni">
            <label for="reg-dni">DNI <span class="auth-required">*</span></label>
            <div class="auth-input-wrap">
              <img src="/img/icon-clipboard.svg" alt="" class="auth-input-icon" />
              <input type="text" id="reg-dni" name="dni"
                placeholder="12345678"
                class="auth-input <%= hasError('dni') %>"
                autocomplete="off" required pattern="\d{8}" inputmode="numeric" maxlength="8" />
            </div>
            <span class="auth-hint" data-hint="dni" style="display:<%= fieldError('dni') ? 'none' : '' %>">8 dígitos numéricos</span>
            <span class="auth-field-error" data-error="dni" style="display:<%= fieldError('dni') ? '' : 'none' %>"><%= fieldError('dni') || '' %></span>
          </div>
        </div>

        <div class="auth-field-row">
          <div class="auth-field" data-field="birth_date">
            <label for="reg-birth_date">Fecha de nacimiento</label>
            <div class="auth-input-wrap">
              <img src="/img/icon-clock.svg" alt="" class="auth-input-icon" />
              <input type="date" id="reg-birth_date" name="birth_date"
                class="auth-input <%= hasError('birth_date') %>"
                autocomplete="bday" />
            </div>
            <span class="auth-field-error" data-error="birth_date" style="display:<%= fieldError('birth_date') ? '' : 'none' %>"><%= fieldError('birth_date') || '' %></span>
          </div>

          <div class="auth-field" data-field="phone">
            <label for="reg-phone">Teléfono <span class="auth-required">*</span></label>
            <div class="auth-input-wrap">
              <img src="/img/icon-heart.svg" alt="" class="auth-input-icon" />
              <input type="tel" id="reg-phone" name="phone"
                placeholder="9XXXXXXXX"
                class="auth-input <%= hasError('phone') %>"
                autocomplete="tel" required pattern="9\d{8}" inputmode="numeric" maxlength="9" />
            </div>
            <span class="auth-hint" data-hint="phone" style="display:<%= fieldError('phone') ? 'none' : '' %>">Empieza con 9, 9 dígitos</span>
            <span class="auth-field-error" data-error="phone" style="display:<%= fieldError('phone') ? '' : 'none' %>"><%= fieldError('phone') || '' %></span>
          </div>
        </div>

        <div class="auth-field">
          <label for="reg-address">Dirección</label>
          <div class="auth-input-wrap">
            <img src="/img/icon-home.svg" alt="" class="auth-input-icon" />
            <input type="text" id="reg-address" name="address"
              placeholder="Av. Ejemplo 123, Lima"
              class="auth-input" autocomplete="street-address" />
          </div>
        </div>
      </div>

      <!-- GRUPO 2: Acceso -->
      <div class="auth-group">
        <div class="auth-group-label">
          <span class="auth-group-num">2</span>
          Datos de acceso
        </div>

        <div class="auth-field" data-field="email">
          <label for="reg-email">Correo electrónico <span class="auth-required">*</span></label>
          <div class="auth-input-wrap">
            <img src="/img/icon-mail.svg" alt="" class="auth-input-icon" />
            <input type="email" id="reg-email" name="email"
              placeholder="usuario@correo.com"
              class="auth-input <%= hasError('email') %>"
              autocomplete="email" required />
          </div>
          <span class="auth-field-error" data-error="email" style="display:<%= fieldError('email') ? '' : 'none' %>"><%= fieldError('email') || '' %></span>
        </div>

        <div class="auth-field" data-field="password">
          <label for="reg-password">Contraseña <span class="auth-required">*</span></label>
          <div class="auth-input-wrap">
            <img src="/img/icon-lock.svg" alt="" class="auth-input-icon" />
            <input type="password" id="reg-password" name="password"
              placeholder="Mínimo 8 caracteres"
              class="auth-input <%= hasError('password') %>"
              autocomplete="new-password" required minlength="8" />
            <button type="button" class="auth-eye-btn" aria-label="Mostrar contraseña" data-target="reg-password">
              <svg class="eye-icon eye-show" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-icon eye-hide" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>
            </button>
          </div>
          <span class="auth-field-error" data-error="password" style="display:<%= fieldError('password') ? '' : 'none' %>"><%= fieldError('password') || '' %></span>
          <!-- Barra de fortaleza -->
          <div class="pw-strength-bar-wrap" id="pwStrengthWrap" style="display:none">
            <div class="pw-strength-track">
              <span class="pw-strength-fill" id="pwStrengthFill"></span>
            </div>
            <span class="pw-strength-text" id="pwStrengthText"></span>
          </div>
          <div class="pw-rules" id="pwRules">
            <span class="pw-rule" id="rule-len"><span class="pw-rule-dot"></span>8+ caracteres</span>
            <span class="pw-rule" id="rule-upper"><span class="pw-rule-dot"></span>Mayúscula</span>
            <span class="pw-rule" id="rule-num"><span class="pw-rule-dot"></span>Número</span>
            <span class="pw-rule" id="rule-special"><span class="pw-rule-dot"></span>Carácter especial</span>
          </div>
        </div>
      </div>

      <!-- GRUPO 3: Emergencia (opcional) -->
      <div class="auth-group auth-group-optional">
        <div class="auth-group-label">
          <span class="auth-group-num">3</span>
          Contacto de emergencia
          <span class="auth-group-optional-tag">opcional</span>
        </div>

        <div class="auth-field-row">
          <div class="auth-field" data-field="emergency_name">
            <label for="reg-emergency_name">Nombre del contacto</label>
            <div class="auth-input-wrap">
              <img src="/img/icon-user.svg" alt="" class="auth-input-icon" />
              <input type="text" id="reg-emergency_name" name="emergency_name"
                placeholder="Ej. Juan García"
                class="auth-input" />
            </div>
            <span class="auth-field-error" data-error="emergency_name" style="display:none"></span>
          </div>

          <div class="auth-field" data-field="emergency_phone">
            <label for="reg-emergency_phone">Teléfono</label>
            <div class="auth-input-wrap">
              <img src="/img/icon-heart.svg" alt="" class="auth-input-icon" />
              <input type="tel" id="reg-emergency_phone" name="emergency_phone"
                placeholder="987654321"
                class="auth-input" pattern="9\d{8}" inputmode="numeric" maxlength="9" />
            </div>
            <span class="auth-hint" data-hint="emergency_phone">Empieza con 9, 9 dígitos</span>
            <span class="auth-field-error" data-error="emergency_phone" style="display:none"></span>
          </div>

          <div class="auth-field" data-field="emergency_relation">
            <label for="reg-emergency_relation">Parentesco</label>
            <div class="auth-input-wrap">
              <img src="/img/icon-shield.svg" alt="" class="auth-input-icon" />
              <select id="reg-emergency_relation" name="emergency_relation" class="auth-input">
                <option value="">Seleccionar...</option>
                <option value="Familiar">Familiar</option>
                <option value="Amigo">Amigo</option>
                <option value="Conyuge">Cónyuge</option>
                <option value="Hijo">Hijo</option>
                <option value="Padre">Padre/Madre</option>
                <option value="Otro">Otro</option>
              </select>
            </div>
            <span class="auth-field-error" data-error="emergency_relation" style="display:none"></span>
          </div>
        </div>
        <span class="auth-hint">Persona a contactar en caso de emergencia</span>
      </div>

      <div class="auth-form-footer">
        <p class="auth-terms">
          Al registrarte aceptas el uso de tus datos para la gestión de citas médicas.
        </p>
        <button type="submit" class="auth-submit-btn">
          <img src="/img/icon-user.svg" alt="" class="inline-icon" />
          Crear mi cuenta
        </button>
      </div>
    </form>

    <div class="auth-panel-footer">
      <span>¿Ya tienes cuenta?</span>
      <a href="/auth/login" class="auth-footer-link">
        <img src="/img/icon-lock.svg" alt="" />
        Iniciar sesión
      </a>
    </div>
  </main>
</section>

<script>
/* Toggle visibilidad contraseña */
document.querySelectorAll('.auth-eye-btn, .password-toggle').forEach(function(btn) {
  btn.addEventListener('click', function() {
    var input = document.getElementById(this.dataset.target);
    if (!input) return;
    var isPassword = input.type === 'password';
    input.type = isPassword ? 'text' : 'password';
    this.querySelector('.eye-show').style.display = isPassword ? 'none' : '';
    this.querySelector('.eye-hide').style.display  = isPassword ? '' : 'none';
    this.setAttribute('aria-label', isPassword ? 'Ocultar contraseña' : 'Mostrar contraseña');
  });
});

/* Fortaleza de contraseña */
(function() {
  var pwInput  = document.getElementById('reg-password');
  var wrap     = document.getElementById('pwStrengthWrap');
  var fill     = document.getElementById('pwStrengthFill');
  var text     = document.getElementById('pwStrengthText');
  var rules    = {
    len:     { el: document.getElementById('rule-len'),     test: function(v){ return v.length >= 8; } },
    upper:   { el: document.getElementById('rule-upper'),   test: function(v){ return /[A-Z]/.test(v); } },
    num:     { el: document.getElementById('rule-num'),     test: function(v){ return /[0-9]/.test(v); } },
    special: { el: document.getElementById('rule-special'), test: function(v){ return /[^A-Za-z0-9]/.test(v); } }
  };
  var levels = [
    { label: '',        cls: '',                pct: 0   },
    { label: 'Débil',   cls: 'pw-weak',         pct: 25  },
    { label: 'Regular', cls: 'pw-fair',         pct: 50  },
    { label: 'Buena',   cls: 'pw-good',         pct: 75  },
    { label: 'Fuerte',  cls: 'pw-strong',       pct: 100 }
  ];
  if (!pwInput) return;
  pwInput.addEventListener('input', function() {
    var v = this.value;
    var score = 0;
    Object.keys(rules).forEach(function(k) {
      var ok = rules[k].test(v);
      if (ok) score++;
      if (rules[k].el) rules[k].el.classList.toggle('pw-rule--ok', ok);
    });
    var lvl = v.length === 0 ? levels[0] : levels[score];
    wrap.style.display = v.length ? 'flex' : 'none';
    fill.style.width = lvl.pct + '%';
    fill.className = 'pw-strength-fill ' + lvl.cls;
    text.textContent = lvl.label;
    text.className = 'pw-strength-text ' + lvl.cls;
  });
})();

/* ============================================================
   VALIDACIÓN EN TIEMPO REAL
   ============================================================ */
(function() {
  var validators = {
    full_name: {
      sel: '#reg-full_name',
      fn: function(v) {
        if (v.trim().length < 5) return 'Nombre completo debe tener al menos 5 caracteres.';
        if (!/^[a-zA-ZáéíóúÁÉÍÓÚñÑ\s]+$/.test(v)) return 'Nombre solo debe contener letras y espacios.';
        return '';
      }
    },
    dni: {
      sel: '#reg-dni',
      fn: function(v) {
        if (!/^\d{8}$/.test(v)) return 'DNI debe tener exactamente 8 dígitos.';
        return '';
      }
    },
    phone: {
      sel: '#reg-phone',
      fn: function(v) {
        if (!/^9\d{8}$/.test(v)) return 'Teléfono debe tener 9 dígitos y comenzar con 9.';
        return '';
      }
    },
    birth_date: {
      sel: '#reg-birth_date',
      fn: function(v) {
        if (v && isNaN(Date.parse(v))) return 'Fecha de nacimiento inválida.';
        return '';
      }
    },
    email: {
      sel: '#reg-email',
      fn: function(v) {
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim())) return 'Ingrese un correo electrónico válido.';
        return '';
      }
    },
    password: {
      sel: '#reg-password',
      fn: function(v) {
        if (v.length < 8) return 'La contraseña debe tener al menos 8 caracteres.';
        if (!/[A-Z]/.test(v)) return 'La contraseña debe contener al menos una mayúscula.';
        if (!/[0-9]/.test(v)) return 'La contraseña debe contener al menos un número.';
        if (!/[!@#$%^&*(),.?":{}|<>_\-]/.test(v)) return 'La contraseña debe contener al menos un carácter especial.';
        return '';
      }
    },
    emergency_name: {
      sel: '#reg-emergency_name',
      fn: function(v) {
        if (v.trim().length > 0 && v.trim().length < 3) return 'Nombre del contacto muy corto.';
        return '';
      }
    },
    emergency_phone: {
      sel: '#reg-emergency_phone',
      fn: function(v) {
        if (v.trim().length > 0 && !/^9\d{8}$/.test(v)) return 'Teléfono de emergencia debe tener 9 dígitos y comenzar con 9.';
        return '';
      }
    },
    emergency_relation: {
      sel: '#reg-emergency_relation',
      fn: function(v) {
        var valid = ['', 'Familiar', 'Amigo', 'Conyuge', 'Hijo', 'Padre', 'Otro'];
        if (v && valid.indexOf(v) === -1) return 'Parentesco inválido.';
        return '';
      }
    }
  };

  function validateField(name) {
    var rule = validators[name];
    if (!rule) return '';
    var input = document.querySelector(rule.sel);
    if (!input) return '';
    var msg = rule.fn(input.value);
    var errEl = document.querySelector('[data-error="' + name + '"]');
    var hintEl = document.querySelector('[data-hint="' + name + '"]');
    if (errEl) {
      errEl.textContent = msg;
      errEl.style.display = msg ? '' : 'none';
    }
    if (hintEl) {
      hintEl.style.display = msg ? 'none' : '';
    }
    var field = input.closest('.auth-field');
    if (field) {
      var inp = field.querySelector('.auth-input');
      if (inp) inp.classList.toggle('auth-input-error', !!msg);
    }
    return msg;
  }

  Object.keys(validators).forEach(function(name) {
    var input = document.querySelector(validators[name].sel);
    if (!input) return;
    var events = name === 'birth_date' ? 'blur change' : 'input blur';
    events.split(' ').forEach(function(evt) {
      input.addEventListener(evt, function() { validateField(name); });
    });
  });

  document.getElementById('registerForm').addEventListener('submit', function(e) {
    var hasError = false;
    Object.keys(validators).forEach(function(name) {
      if (validateField(name)) hasError = true;
    });
    if (hasError) e.preventDefault();
  });
})();
</script>

<%- include('../partials/foot') %>
