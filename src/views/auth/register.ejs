<%- include('../partials/head') %>
<%- include('../partials/flash') %>

<section class="page-hero card">
  <img src="/img/hero-register.svg" alt="Ilustracion de registro de paciente" />
  <div class="page-hero-copy">
    <span class="page-kicker"><img src="/img/icon-user.svg" alt="" class="inline-icon" />Alta de paciente</span>
    <h2>Registre su cuenta y acceda al sistema de citas</h2>
    <p>Un proceso simple, ordenado y orientado a que el paciente llegue rápido a su atención.</p>
  </div>
</section>

<section class="card auth-card auth-card-wide">
  <h2>Registro de Paciente</h2>
  <p>Complete sus datos para reservar citas médicas en línea.</p>
  <form method="post" action="/auth/register" class="grid-form two-cols register-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <label><img src="/img/icon-user.svg" alt="" class="inline-icon" />Nombre completo</label>
    <input type="text" name="full_name" placeholder="Nombre y apellidos" required />

    <label><img src="/img/icon-mail.svg" alt="" class="inline-icon" />Correo electrónico</label>
    <input type="email" name="email" placeholder="usuario@correo.com" required />

    <label><img src="/img/icon-lock.svg" alt="" class="inline-icon" />Contraseña</label>
    <input type="password" name="password" placeholder="Cree una contraseña segura" required />

    <label><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />DNI</label>
    <input type="text" name="dni" placeholder="Número de documento" required />

    <label><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Teléfono</label>
    <input type="text" name="phone" placeholder="Número de contacto" required />

    <label><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Fecha de nacimiento</label>
    <input type="date" name="birth_date" />

    <label><img src="/img/icon-home.svg" alt="" class="inline-icon" />Dirección</label>
    <input type="text" name="address" placeholder="Dirección domiciliaria" />

    <label><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Contacto de emergencia</label>
    <input type="text" name="emergency_contact" placeholder="Nombre y teléfono" />

    <button type="submit" class="btn auth-submit">Crear cuenta</button>
  </form>
  <p class="helper">¿Ya tiene cuenta? <a href="/auth/login">Inicie sesión</a>.</p>
</section>

<%- include('../partials/foot') %>