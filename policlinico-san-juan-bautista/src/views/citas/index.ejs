<%- include('../partials/head') %>
<%- include('../partials/flash') %>

<section class="hero-media card">
  <img src="/img/hero-appointments.svg" alt="Ilustracion de agenda y reserva de citas" />
</section>

<section class="page-hero card compact-hero">
  <div class="page-hero-copy">
    <span class="page-kicker"><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Citas</span>
    <h2>Reserva, seguimiento y control de atención</h2>
    <p>El flujo está diseñado para que el paciente y el equipo clínico tengan claridad total sobre la agenda.</p>
  </div>
</section>

<% if (currentUser.role === 'paciente') { %>
<section class="card">
  <h2><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Reservar Cita</h2>
  <form method="get" action="/citas/disponibilidad" class="grid-form two-cols register-form">
    <label><img src="/img/icon-doctor.svg" alt="" class="inline-icon" />Médico</label>
    <select name="doctor_id" required>
      <option value="">Seleccione</option>
      <% doctors.forEach((doctor) => { %>
        <option value="<%= doctor.id %>" <%= selectedDoctorId === doctor.id ? 'selected' : '' %>>
          <%= doctor.full_name %> - <%= doctor.specialty %>
        </option>
      <% }) %>
    </select>

    <label><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Fecha</label>
    <input type="date" name="appointment_date" value="<%= selectedDate || '' %>" required />

    <button type="submit" class="btn auth-submit">Consultar disponibilidad</button>
  </form>

  <% if (slots.length) { %>
    <form method="post" action="/citas" class="grid-form two-cols register-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="doctor_id" value="<%= selectedDoctorId %>" />
      <input type="hidden" name="appointment_date" value="<%= selectedDate %>" />

      <label><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Horario disponible</label>
      <select name="start_time" required>
        <% slots.forEach((slot) => { %>
          <option value="<%= slot %>"><%= slot %></option>
        <% }) %>
      </select>

      <label><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Motivo de consulta</label>
      <input type="text" name="reason" required />

      <button type="submit" class="btn auth-submit">Confirmar cita</button>
    </form>
  <% } else if (selectedDoctorId && selectedDate) { %>
    <p class="helper">No hay horarios disponibles para la fecha seleccionada.</p>
  <% } %>
</section>
<% } %>

<section class="card">
  <h2><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Listado de Citas</h2>
  <table>
    <thead>
      <tr>
        <th>Fecha</th>
        <th>Hora</th>
        <th>Paciente</th>
        <th>Médico</th>
        <th>Especialidad</th>
        <th>Estado</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% appointments.forEach((a) => { %>
        <tr>
          <td><%= a.appointment_date %></td>
          <td><%= a.start_time %> - <%= a.end_time %></td>
          <td><%= a.patient_name %></td>
          <td><%= a.doctor_name %></td>
          <td><%= a.specialty %></td>
          <td><span class="status status-<%= a.status %>"><%= a.status %></span></td>
          <td>
            <% if (a.status === 'pendiente' && (currentUser.role === 'admin' || currentUser.role === 'medico')) { %>
              <form method="post" action="/citas/<%= a.id %>/completar" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-secondary action-btn"><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Completar</button>
              </form>
            <% } %>

            <% if (a.status === 'pendiente') { %>
              <form method="post" action="/citas/<%= a.id %>/cancelar" class="inline-form">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-danger action-btn"><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Cancelar</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</section>

<%- include('../partials/foot') %>