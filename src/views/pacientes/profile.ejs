<%- include('../partials/head') %>
<%- include('../partials/flash') %>

<!-- HERO del perfil -->
<section class="pac-profile-hero card">
  <div class="pac-profile-hero-copy">
    <div class="pac-profile-avatar-wrap">
      <div class="pac-profile-avatar">
        <%= patient.full_name.split(' ').filter((_,i,a)=>i===0||i===a.length-1).map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
      </div>
      <div>
        <h2><%= patient.full_name %></h2>
        <span class="pac-profile-badge">
          <img src="/img/icon-user.svg" alt="" style="width:12px;height:12px;filter:brightness(0) invert(1);opacity:0.85;margin-right:3px;vertical-align:middle" />
          Paciente
        </span>
      </div>
    </div>
    <div class="pac-profile-quick-info">
      <div class="pac-profile-info-item">
        <img src="/img/icon-mail.svg" alt="" />
        <span><%= patient.email %></span>
      </div>
      <div class="pac-profile-info-item">
        <img src="/img/icon-clipboard.svg" alt="" />
        <span>DNI <%= patient.dni %></span>
      </div>
      <% if (patient.phone) { %>
      <div class="pac-profile-info-item">
        <img src="/img/icon-heart.svg" alt="" />
        <span><%= patient.phone %></span>
      </div>
      <% } %>
    </div>
  </div>
  <div class="pac-profile-hero-media">
    <img src="/img/hero-profile.svg" alt="Perfil del paciente" />
  </div>
</section>

<!-- LAYOUT: formulario + disponibilidad -->
<div class="mgmt-layout">

  <!-- FORMULARIO DE EDICIÓN -->
  <aside class="mgmt-sidebar">
    <div class="card mgmt-form-card">
      <div class="mgmt-form-header">
        <span class="page-kicker"><img src="/img/icon-user.svg" alt="" class="inline-icon" />Editar datos</span>
        <h3>Mi perfil</h3>
        <p>Mantén tus datos actualizados para que el equipo médico pueda contactarte.</p>
      </div>

      <form method="post" action="/pacientes/perfil" class="reg-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

        <fieldset class="reg-fieldset">
          <legend class="reg-legend">
            <span class="reg-legend-num">1</span>
            Información personal
          </legend>

          <div class="reg-field">
            <label for="pf-full_name">Nombre completo <span class="reg-required">*</span></label>
            <div class="reg-input-wrap">
              <img src="/img/icon-user.svg" alt="" class="reg-input-icon" />
              <input type="text" id="pf-full_name" name="full_name"
                value="<%= patient.full_name %>" class="reg-input" autocomplete="name" required />
            </div>
          </div>

          <div class="reg-field-row">
            <div class="reg-field">
              <label>Correo</label>
              <div class="reg-input-wrap">
                <img src="/img/icon-mail.svg" alt="" class="reg-input-icon" />
                <input type="email" value="<%= patient.email %>" class="reg-input pac-disabled-input" disabled />
              </div>
              <span class="reg-hint">No editable</span>
            </div>
            <div class="reg-field">
              <label>DNI</label>
              <div class="reg-input-wrap">
                <img src="/img/icon-clipboard.svg" alt="" class="reg-input-icon" />
                <input type="text" value="<%= patient.dni %>" class="reg-input pac-disabled-input" disabled />
              </div>
              <span class="reg-hint">No editable</span>
            </div>
          </div>

          <div class="reg-field">
            <label for="pf-phone">Teléfono <span class="reg-required">*</span></label>
            <div class="reg-input-wrap">
              <img src="/img/icon-heart.svg" alt="" class="reg-input-icon" />
              <input type="tel" id="pf-phone" name="phone"
                value="<%= patient.phone %>" class="reg-input" autocomplete="tel" required />
            </div>
          </div>

          <div class="reg-field">
            <label for="pf-address">Dirección <span class="reg-required">*</span></label>
            <div class="reg-input-wrap">
              <img src="/img/icon-home.svg" alt="" class="reg-input-icon" />
              <input type="text" id="pf-address" name="address"
                value="<%= patient.address || '' %>" class="reg-input" autocomplete="street-address" required />
            </div>
          </div>
        </fieldset>

        <fieldset class="reg-fieldset">
          <legend class="reg-legend">
            <span class="reg-legend-num">2</span>
            Contacto de emergencia <span class="reg-legend-optional">(opcional)</span>
          </legend>
          <div class="reg-field">
            <label for="pf-emergency">Nombre y teléfono</label>
            <div class="reg-input-wrap">
              <img src="/img/icon-shield.svg" alt="" class="reg-input-icon" />
              <input type="text" id="pf-emergency" name="emergency_contact"
                value="<%= patient.emergency_contact || '' %>"
                placeholder="Ej. Juan García — 987654321"
                class="reg-input" />
            </div>
            <span class="reg-hint">Persona a contactar en caso de emergencia</span>
          </div>
        </fieldset>

        <button type="submit" class="btn auth-submit" style="width:100%;justify-content:center;min-height:46px;margin-top:0.25rem">
          <img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Guardar cambios
        </button>
      </form>
    </div>
  </aside>

  <!-- DISPONIBILIDAD DE MÉDICOS -->
  <section class="mgmt-main">
    <div class="card">
      <div class="section-title-wrap" style="margin-bottom:0.9rem">
        <div>
          <h3><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Médicos disponibles ahora</h3>
          <p class="mgmt-list-sub">Consulta qué especialistas están en horario de atención hoy</p>
        </div>
        <span class="table-count"><%= availabilitySummary.inShift %> en horario</span>
      </div>

      <!-- Summary pills -->
      <div class="pac-avail-summary">
        <div class="pac-avail-pill pac-avail-in">
          <span class="pac-avail-dot pac-avail-dot-in"></span>
          <strong><%= availabilitySummary.inShift %></strong> en horario
        </div>
        <div class="pac-avail-pill pac-avail-out">
          <span class="pac-avail-dot pac-avail-dot-out"></span>
          <strong><%= availabilitySummary.outOfShift %></strong> fuera de horario
        </div>
      </div>

      <% if (!doctorsAvailability.length) { %>
        <div class="tbl-empty">
          <div class="tbl-empty-icon"><img src="/img/icon-doctor.svg" alt="" /></div>
          <strong>Sin médicos registrados</strong>
          <p>No hay especialistas configurados en el sistema.</p>
        </div>
      <% } else { %>
        <!-- Cards de disponibilidad en lugar de tabla -->
        <div class="pac-avail-cards">
          <% doctorsAvailability.forEach((doc) => { %>
            <div class="pac-avail-card <%= doc.is_in_shift ? 'pac-avail-card-in' : 'pac-avail-card-out' %>">
              <div class="pac-avail-card-avatar">
                <%= doc.full_name.charAt(0).toUpperCase() %>
              </div>
              <div class="pac-avail-card-info">
                <strong><%= doc.full_name %></strong>
                <span class="pac-avail-specialty"><%= doc.specialty %></span>
                <div class="pac-avail-meta">
                  <% if (doc.office) { %>
                    <small><img src="/img/icon-home.svg" alt="" style="width:11px;opacity:0.4;vertical-align:middle;margin-right:2px" />Consultorio <%= doc.office %></small>
                  <% } %>
                  <% if (doc.today_schedule && doc.today_schedule !== 'Sin horario hoy') { %>
                    <small><img src="/img/icon-clock.svg" alt="" style="width:11px;opacity:0.4;vertical-align:middle;margin-right:2px" /><%= doc.today_schedule %></small>
                  <% } %>
                </div>
              </div>
              <span class="status <%= doc.is_in_shift ? 'status-in-shift' : 'status-out-shift' %>">
                <%= doc.is_in_shift ? 'En horario' : 'Fuera de horario' %>
              </span>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>
  </section>
</div>

<%- include('../partials/foot') %>
