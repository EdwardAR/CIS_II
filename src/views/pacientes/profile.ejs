<%- include('../partials/head') %>
<%- include('../partials/flash') %>

<section class="page-hero card">
  <img src="/img/hero-profile.svg" alt="Ilustracion de perfil de paciente" />
  <div class="page-hero-copy">
    <span class="page-kicker"><img src="/img/icon-user.svg" alt="" class="inline-icon" />Perfil clínico</span>
    <h2>Gestiona tus datos con seguridad y claridad</h2>
    <p>Mantenga actualizados sus datos de contacto para facilitar recordatorios y coordinación de citas.</p>
  </div>
</section>

<section class="card">
  <h2><img src="/img/icon-user.svg" alt="" class="inline-icon" />Perfil del Paciente</h2>
  <form method="post" action="/pacientes/perfil" class="grid-form two-cols register-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <label><img src="/img/icon-user.svg" alt="" class="inline-icon" />Nombre completo</label>
    <input type="text" name="full_name" value="<%= patient.full_name %>" required />

    <label><img src="/img/icon-mail.svg" alt="" class="inline-icon" />Correo</label>
    <input type="email" value="<%= patient.email %>" disabled />

    <label><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />DNI</label>
    <input type="text" value="<%= patient.dni %>" disabled />

    <label><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Teléfono</label>
    <input type="text" name="phone" value="<%= patient.phone %>" required />

    <label><img src="/img/icon-home.svg" alt="" class="inline-icon" />Dirección</label>
    <input type="text" name="address" value="<%= patient.address || '' %>" required />

    <label><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Contacto emergencia</label>
    <input type="text" name="emergency_contact" value="<%= patient.emergency_contact || '' %>" />

    <button type="submit" class="btn auth-submit">Guardar cambios</button>
  </form>
</section>

<section class="card availability-card">
  <div class="section-title-wrap">
    <h2><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Disponibilidad de médicos</h2>
    <span class="table-count"><%= availabilitySummary.inShift %> en horario ahora</span>
  </div>

  <div class="availability-notice">
    <p>
      <strong><%= availabilitySummary.inShift %></strong> en horario,
      <strong><%= availabilitySummary.outOfShift %></strong> fuera de horario.
      Esta vista se calcula según los turnos activos registrados hoy.
    </p>
  </div>

  <div class="table-shell">
    <table>
      <thead>
        <tr>
          <th><img src="/img/icon-doctor.svg" alt="" class="inline-icon" />Médico</th>
          <th><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Especialidad</th>
          <th><img src="/img/icon-home.svg" alt="" class="inline-icon" />Consultorio</th>
          <th><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Turno de hoy</th>
          <th><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Estado actual</th>
        </tr>
      </thead>
      <tbody>
        <% doctorsAvailability.forEach((doctor) => { %>
          <tr>
            <td><%= doctor.full_name %></td>
            <td><%= doctor.specialty %></td>
            <td><%= doctor.office || '-' %></td>
            <td><%= doctor.today_schedule %></td>
            <td>
              <span class="status <%= doctor.is_in_shift ? 'status-in-shift' : 'status-out-shift' %>">
                <%= doctor.is_in_shift ? 'En horario' : 'Fuera de horario' %>
              </span>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('../partials/foot') %>