<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Policlínico San Juan Bautista</title>
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? pageDescription : 'Sistema web de gestión clínica para citas, pacientes, médicos y administración.' %>" />
  <link rel="icon" type="image/svg+xml" href="/img/logo-mark.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %>">
  <div class="background-shape"></div>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand-wrap">
        <img src="/img/logo-mark.svg" alt="Logo Policlínico" class="brand-logo" />
        <div>
          <h1>Policlínico San Juan Bautista</h1>
          <p>Sistema Web de Gestión de Citas</p>
        </div>
      </div>
      <% if (!currentUser && typeof pageClass !== 'undefined' && pageClass === 'home-page') { %>
        <div class="public-topbar-actions" aria-label="Accesos rápidos">
          <a href="/auth/login" class="topbar-action-link">Iniciar sesión</a>
          <a href="/auth/register" class="topbar-action-link topbar-action-link-accent">Crear paciente</a>
        </div>
      <% } %>
      <% if (currentUser) {
        const fullName = (currentUser.full_name || 'Usuario').trim();
        const tokens = fullName.split(/\s+/).filter(Boolean);
        const honorifics = new Set(['dr', 'dra', 'doctor', 'doctora', 'sr', 'sra', 'srta', 'lic', 'ing']);
        let tokenIndex = 0;
        while (tokenIndex < tokens.length && honorifics.has(tokens[tokenIndex].toLowerCase().replace(/[.,]/g, ''))) {
          tokenIndex += 1;
        }
        const firstName = tokens[tokenIndex] || tokens[0] || 'Usuario';
        const displayName = tokens.slice(tokenIndex, tokenIndex + 2).join(' ') || fullName;
        const avatarLetter = firstName.charAt(0).toUpperCase();
        const avatarLetter2 = tokens.length > 1 ? tokens[tokens.length - 1].charAt(0).toUpperCase() : '';
        const roleLabel = { admin: 'Administrador', medico: 'Médico', paciente: 'Paciente' };
        const roleIcon  = { admin: '/img/icon-shield.svg', medico: '/img/icon-doctor.svg', paciente: '/img/icon-user.svg' };
        const roleColor = { admin: '#7c5fc0', medico: '#0d7fa3', paciente: '#28a262' };
        const profileLink = {
          admin:    '/admin',
          medico:   '/medicos/mi-panel',
          paciente: '/pacientes/perfil'
        };
      %>

        <!-- Avatar con dropdown de perfil -->
        <div class="profile-chip" id="profileChip" aria-label="Menú de usuario" aria-haspopup="true" aria-expanded="false" tabindex="0" role="button">
          <div class="profile-chip-avatar" style="background:linear-gradient(135deg,<%= roleColor[currentUser.role] || '#0d7fa3' %> 0%,<%= roleColor[currentUser.role] ? roleColor[currentUser.role]+'cc' : '#0a5f7a' %> 100%)">
            <%= avatarLetter %><%= avatarLetter2 %>
          </div>
          <div class="profile-chip-info">
            <span class="profile-chip-name"><%= displayName %></span>
            <span class="profile-chip-role"><%= roleLabel[currentUser.role] || 'Usuario' %></span>
          </div>
          <svg class="profile-chip-caret" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </div>

        <!-- Panel de perfil desplegable -->
        <div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Opciones de usuario">
          <!-- Cabecera con avatar grande -->
          <div class="profile-dropdown-header">
            <div class="profile-dropdown-avatar" style="background:linear-gradient(135deg,<%= roleColor[currentUser.role] || '#0d7fa3' %> 0%,<%= roleColor[currentUser.role] ? roleColor[currentUser.role]+'cc' : '#0a5f7a' %> 100%)">
              <%= avatarLetter %><%= avatarLetter2 %>
            </div>
            <div class="profile-dropdown-identity">
              <strong><%= fullName %></strong>
              <span><%= currentUser.email %></span>
              <div class="profile-dropdown-badge" style="background:<%= roleColor[currentUser.role] || '#0d7fa3' %>18;color:<%= roleColor[currentUser.role] || '#0d7fa3' %>;border-color:<%= roleColor[currentUser.role] || '#0d7fa3' %>44">
                <img src="<%= roleIcon[currentUser.role] || '/img/icon-user.svg' %>" alt="" style="width:11px;height:11px;filter:none;opacity:0.75" />
                <%= roleLabel[currentUser.role] || 'Usuario' %>
              </div>
            </div>
          </div>

          <div class="profile-dropdown-sep"></div>

          <!-- Accesos rápidos por rol -->
          <div class="profile-dropdown-links" role="group">
            <% if (currentUser.role === 'paciente') { %>
              <a href="/pacientes/perfil" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-user.svg" alt="" />
                </span>
                <div>
                  <strong>Mi perfil</strong>
                  <small>Ver y editar mis datos</small>
                </div>
              </a>
              <a href="/citas" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-calendar.svg" alt="" />
                </span>
                <div>
                  <strong>Mis citas</strong>
                  <small>Reservar o gestionar citas</small>
                </div>
              </a>
            <% } %>

            <% if (currentUser.role === 'medico') { %>
              <a href="/medicos/mi-panel" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-doctor.svg" alt="" />
                </span>
                <div>
                  <strong>Mi panel</strong>
                  <small>Agenda y atenciones del día</small>
                </div>
              </a>
              <a href="/citas" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-calendar.svg" alt="" />
                </span>
                <div>
                  <strong>Agenda completa</strong>
                  <small>Ver todas las citas</small>
                </div>
              </a>
            <% } %>

            <% if (currentUser.role === 'admin') { %>
              <a href="/admin" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-shield.svg" alt="" />
                </span>
                <div>
                  <strong>Panel admin</strong>
                  <small>Métricas y control operativo</small>
                </div>
              </a>
              <a href="/medicos" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-doctor.svg" alt="" />
                </span>
                <div>
                  <strong>Gestionar médicos</strong>
                  <small>Equipo y horarios</small>
                </div>
              </a>
              <a href="/admin/calificaciones" class="profile-dropdown-link" role="menuitem">
                <span class="profile-dropdown-link-icon">
                  <img src="/img/icon-heart.svg" alt="" />
                </span>
                <div>
                  <strong>Calificaciones</strong>
                  <small>Satisfacción del servicio</small>
                </div>
              </a>
            <% } %>
          </div>

          <div class="profile-dropdown-sep"></div>

          <!-- Cerrar sesión -->
          <div class="profile-dropdown-footer">
            <form method="post" action="/auth/logout" class="inline-form" style="width:100%">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="profile-logout-btn" data-loading-text="Cerrando sesión...">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Cerrar sesión
              </button>
            </form>
          </div>
        </div>

      <% } %>
    </div>
  </header>
  <% if (currentUser) { %>
    <%- include('nav') %>
  <% } %>
  <main class="container">
    <%
      const reminderItems = Array.isArray(typeof autoReminders === 'undefined' ? [] : autoReminders) ? (typeof autoReminders === 'undefined' ? [] : autoReminders) : [];
      const reminderCount = typeof autoRemindersCount === 'number' ? autoRemindersCount : reminderItems.length;
      const notificationItems = Array.isArray(typeof systemNotifications === 'undefined' ? [] : systemNotifications) ? (typeof systemNotifications === 'undefined' ? [] : systemNotifications) : [];
      const notificationCount = typeof systemNotificationsCount === 'number' ? systemNotificationsCount : notificationItems.length;
    %>
    <% if (notificationCount && pageTitle === 'Calificaciones') { %>
      <section class="card system-notifications-shell">
        <div class="section-title-wrap">
          <h2><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Notificaciones clínicas</h2>
          <span class="table-count"><%= notificationCount %> sin leer</span>
        </div>
        <div class="system-notifications-list">
          <% notificationItems.forEach((notification) => { %>
            <article class="system-notification-card notification-<%= notification.tone %>">
              <div class="system-notification-copy">
                <span class="system-notification-pill"><%= notification.badge %></span>
                <strong><%= notification.title %></strong>
                <p><%= notification.message %></p>
              </div>
              <div class="system-notification-actions">
                <% if (notification.action_url) { %>
                  <a href="<%= notification.action_url %>" class="btn btn-secondary action-btn"><img src="/img/icon-calendar.svg" alt="" class="inline-icon" /><%= notification.actionLabel %></a>
                <% } %>
                <form method="post" action="/notificaciones/<%= notification.id %>/leer" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-edit action-btn" data-loading-text="Marcando..."><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Marcar como leída</button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>
    <% if (
      currentUser &&
      pageTitle !== 'Panel administrativo' &&
      pageTitle !== 'Sistema de citas' &&
      pageTitle !== 'Panel del medico'
    ) { 
      const userName = currentUser.full_name || 'Usuario';
      const roleLabelMap = {
        admin: 'acceso administrativo',
        medico: 'seguimiento clínico',
        paciente: 'gestión de citas'
      };
      const greetingByRole = {
        admin: 'Bienvenido',
        medico: 'Bienvenido(a)',
        paciente: 'Bienvenida'
      };
    %>
      <section class="user-welcome card">
        <div class="user-welcome-copy">
          <span class="page-kicker"><img src="/img/icon-user.svg" alt="" class="inline-icon" />Sesión activa</span>
          <h2><%= greetingByRole[currentUser.role] || 'Bienvenido' %>, <%= userName %></h2>
          <p>Te encuentras en <%= roleLabelMap[currentUser.role] || 'el sistema' %>. Aquí tienes un acceso rápido y ordenado a tus funciones.</p>
        </div>
      </section>
    <% } %>
    <% if (reminderCount) { %>
      <section class="card auto-reminders-shell">
        <div class="section-title-wrap">
          <h2><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Recordatorios automáticos</h2>
          <span class="table-count"><%= reminderCount %> próximos</span>
        </div>
        <div class="auto-reminders-list">
          <% reminderItems.forEach((reminder) => { %>
            <article class="auto-reminder-card auto-reminder-<%= reminder.urgency %>">
              <span class="auto-reminder-pill"><%= reminder.title %></span>
              <p><%= reminder.message %></p>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>