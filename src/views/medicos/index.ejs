<%- include('../partials/head') %>
<%- include('../partials/flash') %>
<%
  const specialtyOptions = Array.isArray(specialties) ? specialties : [];
  const doctorRows = Array.isArray(doctors) ? doctors : [];
  const activeSpecialty = typeof selectedSpecialty === 'string' ? selectedSpecialty : '';
%>

<section class="page-hero card">
  <img src="/img/hero-doctors.svg" alt="Ilustracion de gestion de medicos" />
  <div class="page-hero-copy">
    <span class="page-kicker"><img src="/img/icon-doctor.svg" alt="" class="inline-icon" />Gestión médica</span>
    <h2>Organiza especialistas, horarios y disponibilidad clínica</h2>
    <p>Controle la estructura médica del policlínico con una interfaz simple y profesional.</p>
  </div>
</section>

<section class="card">
  <h2>Gestión de Médicos</h2>
  <form method="post" action="/medicos" class="grid-form two-cols register-form">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
    <label><img src="/img/icon-user.svg" alt="" class="inline-icon" />Nombre completo</label>
    <input type="text" name="full_name" required />

    <label><img src="/img/icon-mail.svg" alt="" class="inline-icon" />Correo</label>
    <input type="email" name="email" required />

    <label><img src="/img/icon-doctor.svg" alt="" class="inline-icon" />Especialidad</label>
    <input type="text" name="specialty" required />

    <label><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Número CMP</label>
    <input type="text" name="license_number" required />

    <label><img src="/img/icon-home.svg" alt="" class="inline-icon" />Consultorio</label>
    <input type="text" name="office" />

    <label><img src="/img/icon-lock.svg" alt="" class="inline-icon" />Contraseña inicial</label>
    <input type="text" name="password" placeholder="Medico123*" />

    <button type="submit" class="btn auth-submit">Registrar Médico</button>
  </form>
</section>

<section class="card">
  <h3><img src="/img/icon-doctor.svg" alt="" class="inline-icon" />Listado de Médicos</h3>
  <form method="get" action="/medicos" class="grid-form two-cols register-form" style="margin-bottom: 1rem;">
    <label><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Filtrar por especialidad</label>
    <select name="specialty">
      <option value="">Todas</option>
      <% specialtyOptions.forEach((specialty) => { %>
        <option value="<%= specialty %>" <%= activeSpecialty === specialty ? 'selected' : '' %>><%= specialty %></option>
      <% }) %>
    </select>

    <button type="submit" class="btn btn-secondary">Aplicar filtro</button>
  </form>

  <table>
    <thead>
      <tr>
        <th>Nombre</th>
        <th>Especialidad</th>
        <th>CMP</th>
        <th>Consultorio</th>
        <th>Horarios</th>
      </tr>
    </thead>
    <tbody>
      <% doctorRows.forEach((doctor) => { %>
        <tr>
          <td><%= doctor.full_name %></td>
          <td><%= doctor.specialty %></td>
          <td><%= doctor.license_number %></td>
          <td><%= doctor.office || '-' %></td>
          <td><a class="btn btn-secondary" href="/medicos/<%= doctor.id %>/horarios">Gestionar</a></td>
        </tr>
      <% }) %>
      <% if (!doctorRows.length) { %>
        <tr>
          <td colspan="5" class="helper">No hay medicos para el filtro seleccionado.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</section>

<%- include('../partials/foot') %>