<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Policlínico San Juan Bautista</title>
  <link rel="icon" type="image/svg+xml" href="/img/logo-mark.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="background-shape"></div>
  <header class="topbar">
    <div class="topbar-inner">
      <div class="brand-wrap">
        <img src="/img/logo-mark.svg" alt="Logo Policlínico" class="brand-logo" />
        <div>
          <h1>Policlínico San Juan Bautista</h1>
          <p>Sistema Web de Gestión de Citas</p>
        </div>
      </div>
      <% if (currentUser) {
        const fullName = (currentUser.full_name || 'Usuario').trim();
        const tokens = fullName.split(/\s+/).filter(Boolean);
        const honorifics = new Set(['dr', 'dra', 'doctor', 'doctora', 'sr', 'sra', 'srta', 'lic', 'ing']);
        let tokenIndex = 0;
        while (tokenIndex < tokens.length && honorifics.has(tokens[tokenIndex].toLowerCase().replace(/[.,]/g, ''))) {
          tokenIndex += 1;
        }
        const firstName = tokens[tokenIndex] || tokens[0] || 'Usuario';
        const displayName = tokens.slice(tokenIndex, tokenIndex + 2).join(' ') || fullName;
        const avatarLetter = firstName.charAt(0).toUpperCase();
        const roleLabel = {
          admin: 'Administrador',
          medico: 'Médico',
          paciente: 'Paciente'
        };
        const roleIcon = {
          admin: '/img/icon-shield.svg',
          medico: '/img/icon-doctor.svg',
          paciente: '/img/icon-user.svg'
        };
      %>
        <aside class="topbar-user-chip" aria-label="Usuario conectado">
          <span class="topbar-user-avatar" aria-hidden="true"><%= avatarLetter %></span>
          <div class="topbar-user-copy">
            <span class="topbar-user-kicker">Sesión activa</span>
            <strong class="topbar-user-name">Bienvenido, <%= displayName %></strong>
            <small>
              <img src="<%= roleIcon[currentUser.role] || '/img/icon-user.svg' %>" alt="" class="inline-icon" />
              <%= roleLabel[currentUser.role] || 'Usuario' %>
            </small>
          </div>
        </aside>
      <% } %>
    </div>
  </header>
  <% if (currentUser) { %>
    <%- include('nav') %>
  <% } %>
  <main class="container">
    <%
      const reminderItems = Array.isArray(typeof autoReminders === 'undefined' ? [] : autoReminders) ? (typeof autoReminders === 'undefined' ? [] : autoReminders) : [];
      const reminderCount = typeof autoRemindersCount === 'number' ? autoRemindersCount : reminderItems.length;
      const notificationItems = Array.isArray(typeof systemNotifications === 'undefined' ? [] : systemNotifications) ? (typeof systemNotifications === 'undefined' ? [] : systemNotifications) : [];
      const notificationCount = typeof systemNotificationsCount === 'number' ? systemNotificationsCount : notificationItems.length;
    %>
    <% if (notificationCount) { %>
      <section class="card system-notifications-shell">
        <div class="section-title-wrap">
          <h2><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Notificaciones clínicas</h2>
          <span class="table-count"><%= notificationCount %> sin leer</span>
        </div>
        <div class="system-notifications-list">
          <% notificationItems.forEach((notification) => { %>
            <article class="system-notification-card notification-<%= notification.tone %>">
              <div class="system-notification-copy">
                <span class="system-notification-pill"><%= notification.badge %></span>
                <strong><%= notification.title %></strong>
                <p><%= notification.message %></p>
              </div>
              <div class="system-notification-actions">
                <% if (notification.action_url) { %>
                  <a href="<%= notification.action_url %>" class="btn btn-secondary action-btn"><img src="/img/icon-calendar.svg" alt="" class="inline-icon" /><%= notification.actionLabel %></a>
                <% } %>
                <form method="post" action="/notificaciones/<%= notification.id %>/leer" class="inline-form">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                  <button type="submit" class="btn btn-edit action-btn" data-loading-text="Marcando..."><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Marcar como leída</button>
                </form>
              </div>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>
    <% if (
      currentUser &&
      pageTitle !== 'Panel administrativo' &&
      pageTitle !== 'Sistema de citas' &&
      pageTitle !== 'Panel del medico'
    ) { 
      const userName = currentUser.full_name || 'Usuario';
      const roleLabelMap = {
        admin: 'acceso administrativo',
        medico: 'seguimiento clínico',
        paciente: 'gestión de citas'
      };
      const greetingByRole = {
        admin: 'Bienvenido',
        medico: 'Bienvenido(a)',
        paciente: 'Bienvenida'
      };
    %>
      <section class="user-welcome card">
        <div class="user-welcome-copy">
          <span class="page-kicker"><img src="/img/icon-user.svg" alt="" class="inline-icon" />Sesión activa</span>
          <h2><%= greetingByRole[currentUser.role] || 'Bienvenido' %>, <%= userName %></h2>
          <p>Te encuentras en <%= roleLabelMap[currentUser.role] || 'el sistema' %>. Aquí tienes un acceso rápido y ordenado a tus funciones.</p>
        </div>
      </section>
    <% } %>
    <% if (reminderCount) { %>
      <section class="card auto-reminders-shell">
        <div class="section-title-wrap">
          <h2><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Recordatorios automáticos</h2>
          <span class="table-count"><%= reminderCount %> próximos</span>
        </div>
        <div class="auto-reminders-list">
          <% reminderItems.forEach((reminder) => { %>
            <article class="auto-reminder-card auto-reminder-<%= reminder.urgency %>">
              <span class="auto-reminder-pill"><%= reminder.title %></span>
              <p><%= reminder.message %></p>
            </article>
          <% }) %>
        </div>
      </section>
    <% } %>