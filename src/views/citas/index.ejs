<%- include('../partials/head') %>
<%- include('../partials/flash') %>
<%
  const dmy =
    typeof formatDateDmy === 'function'
      ? formatDateDmy
      : (value) => {
          if (!value || typeof value !== 'string') return value;
          const [year, month, day] = value.split('-');
          if (!year || !month || !day) return value;
          return `${day}-${month}-${year}`;
        };
%>

<section class="card appointments-hero">
  <div class="appointments-hero-copy">
    <span class="page-kicker"><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Citas</span>
    <h2>Agenda clínica con foco operativo</h2>
    <p>Gestiona reservas, seguimiento y estados de atención desde una vista central para todo el equipo.</p>

    <div class="appointments-insight">
      <strong>Resumen rápido</strong>
      <p><%= appointmentSummary.today %> citas para hoy y <%= appointmentSummary.upcoming %> próximas por atender.</p>
    </div>

    <div class="appointments-kpis">
      <article class="appointment-kpi">
        <span>Total</span>
        <strong><%= appointmentSummary.total %></strong>
      </article>
      <article class="appointment-kpi">
        <span>Pendientes</span>
        <strong><%= appointmentSummary.pending %></strong>
      </article>
      <article class="appointment-kpi">
        <span>Completadas</span>
        <strong><%= appointmentSummary.completed %></strong>
      </article>
      <article class="appointment-kpi">
        <span>Canceladas</span>
        <strong><%= appointmentSummary.cancelled %></strong>
      </article>
      <article class="appointment-kpi">
        <span>Reprogramadas</span>
        <strong><%= appointmentSummary.reprogrammed %></strong>
      </article>
      <article class="appointment-kpi">
        <span>Solicitudes</span>
        <strong><%= appointmentSummary.rescheduleRequested %></strong>
      </article>
    </div>
  </div>
  <div class="appointments-hero-media">
    <img src="/img/hero-appointments.svg" alt="Ilustracion de agenda y reserva de citas" />
  </div>
</section>

<% if (currentUser.role === 'paciente') { %>
<section class="card booking-shell">
  <div class="section-title-wrap">
    <h2><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Reservar Cita</h2>
    <span class="table-count">Paciente</span>
  </div>

  <form method="get" action="/citas/disponibilidad" class="grid-form two-cols register-form reservation-filter-form">
    <label><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Especialidad</label>
    <select name="specialty" id="booking-specialty" required>
      <option value="">Seleccione especialidad</option>
      <% specialties.forEach((specialty) => { %>
        <option value="<%= specialty %>" <%= selectedSpecialty === specialty ? 'selected' : '' %>><%= specialty %></option>
      <% }) %>
    </select>

    <label><img src="/img/icon-doctor.svg" alt="" class="inline-icon" />Médico</label>
    <select name="doctor_id" id="booking-doctor" required>
      <option value="">Seleccione un médico</option>
      <% doctors.forEach((doctor) => { %>
        <option
          value="<%= doctor.id %>"
          data-specialty="<%= doctor.specialty %>"
          <%= selectedDoctorId === doctor.id ? 'selected' : '' %>
        >
          <%= doctor.full_name %> - <%= doctor.specialty %><%= doctor.office ? ` (Consultorio ${doctor.office})` : '' %>
        </option>
      <% }) %>
    </select>

    <p class="helper booking-specialty-helper" id="booking-specialty-helper">
      Elige una especialidad para ver solo los médicos correspondientes.
    </p>

    <label><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Fecha</label>
    <input type="date" name="appointment_date" value="<%= selectedDate || '' %>" required />

    <button type="submit" class="btn auth-submit">Consultar disponibilidad</button>
  </form>

  <% if (selectedDoctor) { %>
    <section class="booking-doctor-schedule">
      <div class="section-title-wrap">
        <h3><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Horarios de <%= selectedDoctor.full_name %></h3>
        <span class="table-count"><%= selectedDoctor.office ? `Consultorio ${selectedDoctor.office}` : 'Consultorio no registrado' %></span>
      </div>

      <% if (selectedDateHasShift === false) { %>
        <p class="helper schedule-warning">El médico no atiende en la fecha seleccionada. Elige otra fecha para ver turnos disponibles.</p>
      <% } else if (selectedDateHasShift === true) { %>
        <p class="helper schedule-ok">El médico atiende en la fecha seleccionada. Puedes continuar con la reserva.</p>
      <% } %>

      <% if (!selectedDoctorSchedule.length) { %>
        <p class="helper">Este médico aún no tiene horarios activos configurados.</p>
      <% } else { %>
        <div class="table-shell">
          <table>
            <thead>
              <tr>
                <th>Día</th>
                <th>Desde</th>
                <th>Hasta</th>
                <th>Bloque</th>
              </tr>
            </thead>
            <tbody>
              <% const dayNames = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado']; %>
              <% selectedDoctorSchedule.forEach((slot) => { %>
                <tr class="<%= selectedDayOfWeek === slot.day_of_week ? 'schedule-day-selected' : '' %>">
                  <td><%= dayNames[slot.day_of_week] %></td>
                  <td><%= slot.start_time %></td>
                  <td><%= slot.end_time %></td>
                  <td><%= slot.slot_minutes %> min</td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  <% } %>

  <% if (slots.length) { %>
    <div class="booking-flow-actions">
      <a
        href="/citas/disponibilidad?specialty=<%= encodeURIComponent(selectedSpecialty || '') %>"
        class="btn btn-secondary"
      >
        <img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Cambiar especialidad o médico
      </a>
      <a href="/citas" class="btn btn-danger">
        <img src="/img/icon-shield.svg" alt="" class="inline-icon" />Cancelar proceso
      </a>
    </div>

    <form
      method="post"
      action="/citas"
      class="grid-form two-cols register-form booking-confirm-form"
      data-confirm="¿Desea confirmar y registrar esta cita?"
    >
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <input type="hidden" name="specialty" value="<%= selectedSpecialty || '' %>" />
      <input type="hidden" name="doctor_id" value="<%= selectedDoctorId %>" />
      <input type="hidden" name="appointment_date" value="<%= selectedDate %>" />

      <label><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Horario disponible</label>
      <select name="start_time" required>
        <% slots.forEach((slot) => { %>
          <option value="<%= slot %>"><%= slot %></option>
        <% }) %>
      </select>

      <label><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Motivo de consulta</label>
      <input type="text" name="reason" required />

      <button type="submit" class="btn auth-submit" data-loading-text="Confirmando cita...">Confirmar cita</button>
    </form>
  <% } else if (selectedDoctorId && selectedDate) { %>
    <p class="helper">No hay horarios disponibles para la fecha seleccionada.</p>
  <% } %>
</section>
<% } %>

<% if (currentUser.role === 'paciente' && pendingRatings.length) { %>
<section class="card satisfaction-shell">
  <div class="section-title-wrap">
    <h2><img src="/img/icon-heart.svg" alt="" class="inline-icon" />Calificaciones pendientes</h2>
    <span class="table-count"><%= pendingRatings.length %> por valorar</span>
  </div>
  <p class="helper">Tu experiencia ayuda a mejorar la atención médica. Califica cada consulta completada una sola vez.</p>

  <div class="satisfaction-grid">
    <% pendingRatings.forEach((appointment) => { %>
      <article class="satisfaction-card" id="calificacion-<%= appointment.id %>">
        <div class="satisfaction-card-header">
          <div>
            <span class="appointment-origin-badge">Atención completada</span>
            <strong><%= appointment.doctor_name %></strong>
            <p><%= dmy(appointment.appointment_date) %> - <%= appointment.start_time %><%= appointment.specialty ? ` · ${appointment.specialty}` : '' %></p>
          </div>
          <span class="rating-chip">Pendiente de calificación</span>
        </div>

        <form
          method="post"
          action="/citas/<%= appointment.id %>/calificar"
          class="rating-form"
        >
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="star-rating" role="radiogroup" aria-label="Calificación de la atención">
            <% for (let star = 5; star >= 1; star -= 1) { %>
              <input id="rating-<%= appointment.id %>-<%= star %>" type="radio" name="rating" value="<%= star %>" required />
              <label for="rating-<%= appointment.id %>-<%= star %>" title="<%= star %> estrella<%= star === 1 ? '' : 's' %>">★</label>
            <% } %>
          </div>

          <label for="comment-<%= appointment.id %>" class="helper">Comentario opcional</label>
          <textarea id="comment-<%= appointment.id %>" name="comment" rows="3" maxlength="250" placeholder="Cuéntanos cómo fue la atención..."></textarea>

          <button type="submit" class="btn auth-submit" data-loading-text="Enviando calificación...">Enviar calificación</button>
        </form>
      </article>
    <% }) %>
  </div>
</section>
<% } %>

<section class="card">
  <div class="section-title-wrap">
    <h2><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Listado de Citas</h2>
    <span class="table-count"><%= appointments.length %> registros</span>
  </div>

  <% if (!appointments.length) { %>
    <p class="helper">No hay citas para mostrar en este momento.</p>
  <% } else { %>
    <div class="table-shell appointments-table-shell">
      <div class="table-shell-scroller">
      <table class="appointments-table">
        <thead>
          <tr>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Paciente</th>
            <th>Médico</th>
            <th>Especialidad</th>
            <th>Consultorio</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr>
        </thead>
        <tbody>
          <% appointments.forEach((a) => { %>
            <tr>
              <td><%= dmy(a.appointment_date) %></td>
              <td><%= a.start_time %> - <%= a.end_time %></td>
              <td><%= a.patient_name %></td>
              <td><%= a.doctor_name %></td>
              <td><%= a.specialty %></td>
              <td><%= a.doctor_office || '-' %></td>
              <td><span class="status status-<%= a.status %>"><%= a.status %></span></td>
              <td class="appointments-actions-cell">
                <div class="appointments-actions-stack">
                  <div class="appointments-actions-badges">
                    <% if (a.is_auto_rescheduled) { %>
                      <span class="appointment-origin-badge">Generada automáticamente tras una reprogramación previa</span>
                    <% } %>

                    <% if (a.status === 'pendiente' && currentUser.role === 'paciente' && a.is_auto_rescheduled) { %>
                      <span class="appointment-origin-note">Esta cita ya es la nueva fecha generada automáticamente. Si necesita otro cambio, contacte al médico o administrador.</span>
                    <% } %>
                  </div>

                  <div class="appointments-actions-row">
                    <% if (a.status === 'pendiente' && (currentUser.role === 'admin' || currentUser.role === 'medico')) { %>
                      <form
                        method="post"
                        action="/citas/<%= a.id %>/completar"
                        class="inline-form"
                        data-confirm="¿Marcar esta cita como completada?"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-secondary action-btn" data-loading-text="Marcando..."><img src="/img/icon-clipboard.svg" alt="" class="inline-icon" />Completar</button>
                      </form>
                    <% } %>

                    <% if (a.status === 'pendiente' && currentUser.role === 'paciente' && !a.is_auto_rescheduled) { %>
                      <form
                        method="post"
                        action="/citas/<%= a.id %>/solicitar-reprogramacion"
                        class="inline-form"
                        data-confirm="¿Enviar una solicitud de reprogramación para esta cita?"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-request action-btn" data-loading-text="Enviando solicitud..."><img src="/img/icon-clock.svg" alt="" class="inline-icon" />Solicitar reprogramación</button>
                      </form>
                    <% } %>

                    <% if (a.status === 'solicitud_reprogramacion' && (currentUser.role === 'admin' || currentUser.role === 'medico')) { %>
                      <form
                        method="post"
                        action="/citas/<%= a.id %>/aprobar-reprogramacion"
                        class="inline-form"
                        data-confirm="¿Aprobar esta reprogramación y generar una nueva cita automática?"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-approve action-btn" data-loading-text="Aprobando..."><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Aprobar reprogramación</button>
                      </form>
                    <% } %>

                    <% if (a.status === 'pendiente') { %>
                      <form
                        method="post"
                        action="/citas/<%= a.id %>/cancelar"
                        class="inline-form"
                      >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                        <button type="submit" class="btn btn-danger btn-danger-soft action-btn" data-loading-text="Cancelando..."><img src="/img/icon-shield.svg" alt="" class="inline-icon" />Cancelar cita</button>
                      </form>
                    <% } %>

                    <% if (currentUser.role === 'admin' || currentUser.role === 'medico') { %>
                      <details class="appointment-edit-inline">
                        <summary class="btn btn-edit action-btn"><img src="/img/icon-pencil.svg" alt="" class="inline-icon" />Editar</summary>
                        <form
                          method="post"
                          action="/citas/<%= a.id %>/editar"
                          class="appointment-edit-form"
                          data-confirm="¿Guardar el nuevo estado de la cita?"
                        >
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                          <label for="status-<%= a.id %>" class="helper">Nuevo estado</label>
                          <select id="status-<%= a.id %>" name="status" required>
                            <option value="pendiente" <%= a.status === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
                            <option value="completada" <%= a.status === 'completada' ? 'selected' : '' %>>Completada</option>
                            <option value="cancelada" <%= a.status === 'cancelada' ? 'selected' : '' %>>Cancelada</option>
                            <option value="reprogramada" <%= a.status === 'reprogramada' ? 'selected' : '' %>>Reprogramada</option>
                          </select>
                          <button type="submit" class="btn action-btn" data-loading-text="Guardando..."><img src="/img/icon-calendar.svg" alt="" class="inline-icon" />Guardar</button>
                        </form>
                      </details>
                    <% } %>
                  </div>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
      </div>
    </div>
  <% } %>
</section>

<%- include('../partials/foot') %>