<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle %> | Policlínico San Juan Bautista</title>
  <link rel="icon" type="image/svg+xml" href="/img/logo-mark.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600;700&family=Work+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <div class="background-shape"></div>
  <header class="topbar">
    <div class="brand-wrap">
      <img src="/img/logo-mark.svg" alt="Logo Policlínico" class="brand-logo" />
      <div>
        <h1>Policlínico San Juan Bautista</h1>
        <p>Sistema Web de Gestión de Citas</p>
      </div>
    </div>
  </header>
  <% if (currentUser) { %>
    <%- include('nav') %>
  <% } %>
  <main class="container">
    <% if (currentUser && pageTitle !== 'Panel administrativo') { 
      const userName = currentUser.full_name || 'Usuario';
      const roleLabelMap = {
        admin: 'acceso administrativo',
        medico: 'seguimiento clínico',
        paciente: 'gestión de citas'
      };
      const greetingByRole = {
        admin: 'Bienvenido',
        medico: 'Bienvenido(a)',
        paciente: 'Bienvenida'
      };
    %>
      <section class="user-welcome card">
        <div class="user-welcome-copy">
          <span class="page-kicker"><img src="/img/icon-user.svg" alt="" class="inline-icon" />Sesión activa</span>
          <h2><%= greetingByRole[currentUser.role] || 'Bienvenido' %>, <%= userName %></h2>
          <p>Te encuentras en <%= roleLabelMap[currentUser.role] || 'el sistema' %>. Aquí tienes un acceso rápido y ordenado a tus funciones.</p>
        </div>
      </section>
    <% } %>